{
  "name": "robot-crawler",
  "version": "0.1.0",
  "private": true,
  "description": "Megaman Legends-inspired 3D dungeon crawler. Vibe Jam 2026 entry.",
  "type": "module",
  "scripts": {
    "compress-models": "node scripts/compress-models.mjs",
    "build:client": "tsc -p tsconfig.client.json",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "watch:client": "tsc -p tsconfig.client.json --watch",
    "dev": "concurrently -k -n tsc,serve -c blue,green \"npm run watch:client\" \"npx serve . -l 3000\"",
    "test": "vitest run"
  },
  "devDependencies": {
    "@colyseus/sdk": "^0.17.0",
    "@dimforge/rapier3d-compat": "^0.19.0",
    "@types/node": "^20.11.0",
    "@types/three": "^0.174.0",
    "concurrently": "^8.2.2",
    "gltf-pipeline": "^4.1.0",
    "serve": "^14.2.4",
    "three": "^0.174.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.0",
    "@types/express": "^4.17.0",
    "@types/pg": "^8.11.0",
    "colyseus": "^0.17.0",
    "express": "^4.21.0",
    "pg": "^8.13.0"
  }
}
